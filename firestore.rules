rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // === ОБЪЯВЛЕНИЯ (ads) ===
    match /ads/{adId} {
      // Чтение — всем
      allow read: if true;
      // Создание — авторизованным
      allow create: if request.auth != null;
      // Обновление и удаление — авторизованным (автор или администратор)
      allow update, delete: if request.auth != null;
    }
    
    // === ЧАТЫ (chats) ===
    match /chats/{chatId} {
      // Создание: проверяем только новый документ (resource.data ещё не существует)
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;
      // Чтение: resource == null когда документ не существует (ref.get() для проверки)
      allow read: if request.auth != null &&
        (resource == null || request.auth.uid in resource.data.participants);
      // Обновление / удаление: только участники существующего чата
      allow update, delete: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      
      // Сообщения в чате
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // === ПРОФИЛИ ПОЛЬЗОВАТЕЛЕЙ (users) ===
    match /users/{userId} {
      // Чтение — всем
      allow read: if true;
      // Запись — только автор может писать свой профиль
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // === ЖАЛОБЫ (reports) ===
    match /reports/{reportId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // === ЗАПРОСЫ В ПОДДЕРЖКУ (supportRequests) ===
    match /supportRequests/{requestId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // === ОТЗЫВЫ (reviews) ===
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // === ЗАБЛОКИРОВАННЫЕ ПОЛЬЗОВАТЕЛИ (blockedUsers) ===
    match /blockedUsers/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
